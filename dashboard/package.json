{
  "name": "optiora-dashboard",
  "version": "0.9.3",
  "description": "OptiOra multi-cloud cost optimization dashboard built with Next.js and React",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "build:turbopack": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit --incremental false",
    "generate-api-client": "python3 ../scripts/generate_openapi_client.py",
    "test:e2e": "playwright test",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "test:e2e:headed": "playwright test --headed"
  },
  "keywords": [
    "finops",
    "cost-optimization",
    "cloud",
    "aws",
    "azure",
    "gcp",
    "oci"
  ],
  "author": "Leandro Michelino - ACE <leandro.michelino@oracle.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "autoprefixer": "^10.4.27",
    "axios": "^1.16.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "postcss": "8.5.14",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
