# OptiOra MCP - Multi-Cloud Cost Automation
# Configuration Template
# Note: OCI is used to (1) HOST the MCP server and (2) ANALYZE OCI costs

# MCP Server
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# AWS Configuration (for cost analysis)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1

# Azure Configuration (for cost analysis)
AZURE_SUBSCRIPTION_ID=your_subscription
AZURE_TENANT_ID=your_tenant
AZURE_CLIENT_ID=your_client
AZURE_CLIENT_SECRET=your_secret

# GCP Configuration (for cost analysis)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# OCI Configuration (for hosting MCP server AND analyzing OCI costs)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=us-phoenix-1

# OCI Deployment Type
# Options: oci-functions (serverless), oci-compute (VM), docker (local)
DEPLOYMENT_TYPE=oci-compute
OCI_FUNCTION_OCID=ocid1.fnfunc.oc1.region..your_function_id
OCI_API_GATEWAY_URL=https://your_api_gateway.apigateway.region.oci.customer-oci.com

# OCI PostgreSQL Database (for audit logs, customer data)
OCI_DB_HOST=your_db_host.subnet.vcn.oraclevcn.com
OCI_DB_PORT=5432
OCI_DB_USER=optiora_user
OCI_DB_PASSWORD=your_db_password
OCI_DB_NAME=optiora

# API Integration (for ticket creation & notifications)
JIRA_API_TOKEN=your_jira_token
JIRA_SERVER_URL=https://your-domain.atlassian.net
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TEAMS_WEBHOOK=https://outlook.webhook.office.com/webhookb2/YOUR/URL

# Business Configuration
REVENUE_SHARE_PERCENTAGE=15
MIN_ANOMALY_THRESHOLD_USD=100
MAX_AUTO_ACTION_SPEND=1000
