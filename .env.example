###############################################################################
# OptiOra - Multi-Cloud FinOps Optimization Platform
# Master Configuration File (Backend + Frontend)
# 
# This file defines all environment variables for both:
# 1. Backend MCP Server (Python) - ran from root: python -m finops_mcp.server
# 2. Frontend Dashboard (React) - ran from dashboard/: npm run dev
# 
# Copy this file to .env and fill in your values
###############################################################################

# ===============================
# 1. FRONTEND (REACT DASHBOARD)
# ===============================

# Backend API endpoint (for frontend to call)
# Local development: http://localhost:8000
# Production: https://api.optiora.io or your OCI deployment
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: Uncomment to enable debug logging in browser console
# NEXT_PUBLIC_DEBUG=true

# Optional: If backend is deployed with a sub-path
# NEXT_PUBLIC_API_PREFIX=/api

# Claude AI API for GenAI Dashboard Features
ANTHROPIC_API_KEY=your_claude_api_key

# ===============================
# 2. BACKEND (MCP SERVER)
# ===============================

# ---- MCP Server Configuration ----
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# ---- AWS Configuration (for cost analysis) ----
# How to get: AWS Console > IAM > Users > Access Keys > Create Access Key
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ---- Azure Configuration (for cost analysis) ----
# How to get: Azure Portal > App Registrations > Create New
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_app_secret

# ---- GCP Configuration (for cost analysis) ----
# How to get: Google Cloud Console > Service Accounts > Create Service Account
# Then download JSON key and point to it
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-service-account.json

# ---- OCI Configuration ----
# Used for: (1) Hosting MCP server, (2) Analyzing OCI costs
# How to get: oci setup config (interactive)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_REGION=us-phoenix-1

# OCI Deployment Type (for OCI_DEPLOYMENT.md script)
# Options: oci-functions (serverless), oci-compute (VM), docker (local)
DEPLOYMENT_TYPE=oci-compute

# OPTIONAL: OCI Functions (if using serverless)
# OCI_FUNCTION_OCID=ocid1.fnfunc.oc1.region..your_function_id
# OCI_API_GATEWAY_URL=https://your_api_gateway.apigateway.region.oci.customer-oci.com

# ---- OCI PostgreSQL Database ----
# Connection details for credential storage, scanning history, audit logs
OCI_DB_HOST=your_db_host.subnet.vcn.oraclevcn.com
OCI_DB_PORT=5432
OCI_DB_USER=optiora_user
OCI_DB_PASSWORD=your_secure_db_password
OCI_DB_NAME=optiora

# ---- Integrations (Optional) ----
# Ticket Creation (Jira)
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_SERVER_URL=https://your-domain.atlassian.net

# Notifications (Slack)
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Notifications (Microsoft Teams)
# TEAMS_WEBHOOK=https://outlook.webhook.office.com/webhookb2/YOUR/URL

# ---- Business Configuration ----
# Enterprise customers: revenue share percentage (15% is default)
REVENUE_SHARE_PERCENTAGE=15

# Minimum cost spike (in USD) to trigger anomaly alerts
MIN_ANOMALY_THRESHOLD_USD=100

# Maximum spend amount for auto-remediation actions (safety limit)
MAX_AUTO_ACTION_SPEND=1000

###############################################################################
# Setup Instructions:
# 
# 1. BACKEND ONLY (Local Development):
#    cp .env.example .env
#    nano .env  # Fill in Cloud Provider credentials (AWS/Azure/GCP/OCI)
#    python3 -m venv .venv && source .venv/bin/activate
#    pip install -r pyproject.toml (or: poetry install)
#    python -m finops_mcp.server
#
# 2. FRONTEND ONLY (Local Development):
#    cd dashboard
#    cp ../.env.example .env.local  # Or create new .env.local with NEXT_PUBLIC_API_URL
#    npm install
#    npm run dev
#
# 3. FULL STACK (Local Development):
#    Terminal 1: python -m finops_mcp.server (backend runs on :8000)
#    Terminal 2: cd dashboard && npm run dev (frontend runs on :3000)
#    Browser: http://localhost:3000
#
# 4. PRODUCTION (OCI):
#    See OCI_DEPLOYMENT.md for complete deployment guide
###############################################################################
