###############################################################################
# OptiOra - Multi-Cloud FinOps Optimization Platform
# Shared environment for the FastAPI backend and Next.js dashboard.
#
# Copy this file to .env and fill in the values you actually use.
###############################################################################

# ===============================
# 1. FRONTEND (NEXT.JS DASHBOARD)
# ===============================

# Backend API endpoint (for frontend to call)
# Local development: http://localhost:8000
# Production: https://api.optiora.io or your OCI deployment
# The OCI deploy script rewrites this to the instance public IP during build.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Dashboard access mode. Default is public direct access with no login wall.
# Set true only when you intentionally want optional auth deployment later.
NEXT_PUBLIC_ENABLE_AUTH=false

# Optional: Uncomment to enable debug logging in browser console
# NEXT_PUBLIC_DEBUG=true

# Optional: If backend is deployed with a sub-path
# NEXT_PUBLIC_API_PREFIX=/api

# OCI GenAI (chat assistant)
# Shared OCI region value used by the AI layer and OCI cost integrations.
# Primary region defaults to London South for OCI GenAI-first deployments.
OCI_REGION=uk-london-1
OCI_GENAI_ENDPOINT=https://inference.generativeai.uk-london-1.oci.oraclecloud.com
OCI_GENAI_MODEL=ocid1.generativeaimodel.oc1..<your_model_ocid>
OCI_COMPARTMENT_OCID=ocid1.compartment.oc1..<your_compartment_ocid>
OCI_TENANCY_OCID=ocid1.tenancy.oc1..<your_tenancy_ocid>
OCI_USER_OCID=ocid1.user.oc1..<your_user_ocid>
OCI_FINGERPRINT=<your_api_key_fingerprint>
# Preferred: point to a readable PEM file on the host running the dashboard.
OCI_PRIVATE_KEY_PATH=~/.oci/oci_api_key.pem
# Optional alternative: inline PEM content with literal \n escapes.
# OCI_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----

# ===============================
# 2. BACKEND (FASTAPI API)
# ===============================

# ---- API Server Configuration ----
PORT=8000
UVICORN_RELOAD=false
ENVIRONMENT=development
ENABLE_AUTH=false
PUBLIC_WORKSPACE_NAME=OptiOra Public Workspace
PUBLIC_WORKSPACE_EMAIL=public@optiora.local
# Allowed frontend origin for backend CORS
FRONTEND_URL=http://localhost:3000
# Required for JWT signing in production. Generate with: openssl rand -hex 32
SECRET_KEY=replace_with_random_64_char_hex
# Local/dev can return reset tokens directly when no mailer is configured.
# Set false in production and deliver reset links through a mail provider.
PASSWORD_RESET_RETURN_TOKEN=true
PASSWORD_RESET_TOKEN_MINUTES=30

# ---- AWS Configuration (for cost analysis) ----
# How to get: AWS Console > IAM > Users > Access Keys > Create Access Key
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
# Optional: comma-separated role ARNs to scan member accounts (AWS Organizations)
# AWS_ORGANIZATION_ROLE_ARNS=arn:aws:iam::111111111111:role/FinOpsReadOnly,arn:aws:iam::222222222222:role/FinOpsReadOnly

# ---- Azure Configuration (for cost analysis) ----
# How to get: Azure Portal > App Registrations > Create New
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
# Optional: comma-separated subscriptions for aggregation
# AZURE_SUBSCRIPTION_IDS=sub_a,sub_b,sub_c
# Optional: management group scope (aggregates all descendant subscriptions)
# AZURE_MANAGEMENT_GROUP_ID=your_management_group_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_app_client_id
AZURE_CLIENT_SECRET=your_azure_app_secret

# ---- GCP Configuration (for cost analysis) ----
# How to get: Google Cloud Console > Service Accounts > Create Service Account
# Then download JSON key and point to it
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/gcp-service-account.json
GCP_PROJECT_ID=your_gcp_project_id
# Optional: comma-separated projects for aggregation
# GCP_PROJECT_IDS=project-a,project-b
# Optional: context metadata for folder/org level reporting
# GCP_FOLDER_ID=123456789012
# GCP_ORGANIZATION_ID=987654321098

# ---- OCI Configuration ----
# Used for analyzing OCI costs through the backend.
# How to get: oci setup config (interactive)
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT

# ---- Database ----
# Preferred: set DATABASE_URL directly.
# Example PostgreSQL URL:
# DATABASE_URL=postgresql+psycopg2://optiora_user:your_secure_db_password@db.example.com:5432/optiora
DATABASE_URL=

# Legacy OCI PostgreSQL fields are still supported when DATABASE_URL is blank.
# The backend will derive DATABASE_URL automatically if these are populated.
OCI_DB_HOST=
OCI_DB_PORT=5432
OCI_DB_USER=
OCI_DB_PASSWORD=
OCI_DB_NAME=optiora

# ---- Integrations (Optional) ----
# Ticket Creation (Jira)
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_SERVER_URL=https://your-domain.atlassian.net

# Notifications (Slack)
# SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Notifications (Microsoft Teams)
# TEAMS_WEBHOOK=https://outlook.webhook.office.com/webhookb2/YOUR/URL

# ---- Business Configuration ----
# Enterprise customers: revenue share percentage (15% is default)
REVENUE_SHARE_PERCENTAGE=15

# Minimum cost spike (in USD) to trigger anomaly alerts
MIN_ANOMALY_THRESHOLD_USD=100

# Maximum spend amount for auto-remediation actions (safety limit)
MAX_AUTO_ACTION_SPEND=1000

# ---- Scan Scheduler (Optional) ----
# Enables periodic scheduler loop that triggers due approved scans.
ENABLE_SCAN_SCHEDULER=false
# Polling interval for due scan checks; approvals still control daily/weekly cadence.
SCAN_SCHEDULER_INTERVAL_MINUTES=60

###############################################################################
# Local quick start:
#
# cp .env.example .env
# python3 -m venv .venv && source .venv/bin/activate
# pip install -e .
# optiora
#
# cd dashboard
# npm install
# npm run dev
###############################################################################
