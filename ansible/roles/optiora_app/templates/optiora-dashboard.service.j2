[Unit]
Description=OptiOra Dashboard
After=network.target optiora-api.service

[Service]
Type=simple
User={{ optiora_app_user }}
Group={{ optiora_app_user }}
WorkingDirectory={{ optiora_app_dir }}/dashboard
EnvironmentFile={{ optiora_app_dir }}/.env
ExecStart=/usr/bin/npm run start -- --hostname 0.0.0.0 --port {{ optiora_dashboard_port }}
Restart=always
RestartSec=10
StandardOutput=append:/var/log/optiora-dashboard.log
StandardError=append:/var/log/optiora-dashboard.log

[Install]
WantedBy=multi-user.target
