SECRET_KEY={{ optiora_secret_key | default(optiora_generated_secret.stdout, true) }}
FRONTEND_URL={{ optiora_frontend_url }}
NEXT_PUBLIC_API_URL={{ optiora_api_url }}
ENABLE_AUTH={{ optiora_enable_auth | default(false, true) | ternary('true', 'false') }}
NEXT_PUBLIC_ENABLE_AUTH={{ optiora_enable_auth | default(false, true) | ternary('true', 'false') }}
PUBLIC_WORKSPACE_NAME={{ optiora_public_workspace_name | default("OptiOra Public Workspace", true) }}
PUBLIC_WORKSPACE_EMAIL={{ optiora_public_workspace_email | default("public@optiora.local", true) }}
PORT={{ optiora_api_port }}
UVICORN_RELOAD=false
ENVIRONMENT=production
PASSWORD_RESET_RETURN_TOKEN=false
PASSWORD_RESET_TOKEN_MINUTES=30
DATABASE_URL={{ optiora_database_url | default("sqlite:///" + optiora_app_dir + "/optiora.db", true) }}
OCI_DB_LICENSE_MODEL={{ optiora_oci_db_license_model | default("BYOL", true) }}
RETENTION_ENABLED={{ optiora_retention_enabled | default(false, true) | ternary('true', 'false') }}
RETENTION_HOT_MONTHS={{ optiora_retention_hot_months | default(3, true) }}
RETENTION_RUN_INTERVAL_HOURS={{ optiora_retention_run_interval_hours | default(24, true) }}
OCI_ARCHIVE_BUCKET={{ optiora_archive_bucket | default("", true) }}
OCI_ARCHIVE_NAMESPACE={{ optiora_archive_namespace | default("", true) }}
OCI_GENAI_ENDPOINT={{ optiora_genai_endpoint | default("https://inference.generativeai.uk-london-1.oci.oraclecloud.com", true) }}
OCI_GENAI_MODEL={{ optiora_genai_model | default("meta.llama-3-70b-instruct", true) }}
OCI_COMPARTMENT_OCID={{ optiora_compartment_ocid | default("", true) }}
OCI_GENAI_COMPARTMENT_ID={{ optiora_genai_compartment_ocid | default("", true) }}
OCI_TENANCY_OCID={{ optiora_tenancy_ocid | default("", true) }}
OCI_USER_OCID={{ optiora_user_ocid | default("", true) }}
OCI_FINGERPRINT={{ optiora_fingerprint | default("", true) }}
OCI_PRIVATE_KEY={{ optiora_private_key | default("", true) }}
OCI_PRIVATE_KEY_PATH={{ optiora_private_key_path | default("", true) }}
OCI_REGION={{ optiora_region | default("uk-london-1", true) }}
{% if optiora_oci_config_file | default("") %}
OCI_CONFIG_FILE={{ optiora_oci_config_file }}
{% endif %}
{% if optiora_oci_profile | default("") %}
OCI_PROFILE={{ optiora_oci_profile }}
{% endif %}
