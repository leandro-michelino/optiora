# Managed by Ansible — do not edit by hand.
# OptiOra nginx reverse-proxy configuration.
#
# When optiora_enable_tls is true this template emits:
#   - port 80  → permanent redirect to https://{{ optiora_domain }}
#   - port 443 → TLS termination, reverse-proxy to the API (:8000) and
#                dashboard (:3000)
#
# When optiora_enable_tls is false a single plain-HTTP server block is
# emitted on port 80 so the application is still reachable before a domain
# and certificate are available.

{% if optiora_enable_tls | bool and optiora_domain %}
# ── HTTP → HTTPS redirect ────────────────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name {{ optiora_domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── HTTPS front door ─────────────────────────────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ optiora_domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ optiora_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ optiora_domain }}/privkey.pem;

    # Modern TLS settings (Mozilla Intermediate)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;
    ssl_session_tickets off;
    ssl_stapling on;
    ssl_stapling_verify on;

    # HSTS (1 year)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;

    # ── Backend endpoints (/api/v1/*, /auth/*, health/docs) ──────────────────
    # Keep Next.js app routes like /api/ai/chat on the dashboard service.
    location ~ ^/(api/v1|auth|health|docs|redoc|openapi\.json) {
        proxy_pass         http://127.0.0.1:{{ optiora_api_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ── Next.js dashboard (everything else) ──────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ optiora_dashboard_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}

{% else %}
# ── Plain HTTP (no TLS configured) ──────────────────────────────────────────
server {
    listen 80;
    listen [::]:80;
    server_name _;

    # ── Backend endpoints (/api/v1/*, /auth/*, health/docs) ──────────────────
    # Keep Next.js app routes like /api/ai/chat on the dashboard service.
    location ~ ^/(api/v1|auth|health|docs|redoc|openapi\.json) {
        proxy_pass         http://127.0.0.1:{{ optiora_api_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }

    # ── Next.js dashboard (everything else) ──────────────────────────────────
    location / {
        proxy_pass         http://127.0.0.1:{{ optiora_dashboard_port }};
        proxy_http_version 1.1;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_send_timeout 120s;
    }
}
{% endif %}
