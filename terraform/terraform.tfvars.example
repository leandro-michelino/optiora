compartment_id = "ocid1.compartment.oc1..your_compartment_ocid"
region         = "uk-london-1"
oci_object_storage_namespace = "your_object_storage_namespace"

# Extra app/data disk. 200 GiB balanced is the recommended default so the
# database, imports, exports, and dashboard build artifacts do not sit on the
# small boot volume.
extra_block_volume_enabled = true
extra_block_volume_size_gbs = 200
extra_block_volume_vpus_per_gb = 10
extra_block_volume_device = "/dev/oracleoci/oraclevdb"

# Restrict ingress to your laptop public IP only.
laptop_cidr = "<your_laptop_public_ip>/32"
# Optional extra public CIDRs (office/VPN egress) allowed by security list.
allowed_public_ingress_cidrs = []
# Expose direct app ports only when needed.
allow_direct_app_ingress = true
# Expose web ports for nginx/TLS front door.
allow_web_ingress = false
# Keep outbound access open by default so the VM can install packages and reach cloud APIs.
egress_cidr = "0.0.0.0/0"

project_code = "optiora"
environment  = "prod"
region_code  = "lhr"
name_suffix  = "001"

vcn_cidr           = "10.50.0.0/16"
public_subnet_cidr = "10.50.1.0/24"
